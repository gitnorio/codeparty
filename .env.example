# Supabase — safe for the browser
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server only, never expose with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# Application origin, without a trailing slash
# Local: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=

# Comma-separated admin emails. Required in production; access fails closed when empty.
NEXT_PUBLIC_ADMIN_EMAILS=admin@example.com

# Development login — keep both unset in Production.
# Enable only locally or on an access-protected Preview deployment.
DEV_LOGIN_ENABLED=false
NEXT_PUBLIC_DEV_LOGIN_ENABLED=false
